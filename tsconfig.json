{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "declaration": true,
        "importHelpers": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "jsx": "react-jsx"
    },
    "include": ["source/**/*"]
}
